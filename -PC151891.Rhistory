inherit.aes = FALSE,
fontface = "bold", size = 3.5) +
coord_cartesian(clip = "off") +
scale_fill_manual(values = site_colors) +
scale_alpha_identity() +
labs(y = "Fitness (mean ± SE)", x = "Site") +
theme_minimal() +
theme(
panel.background = element_blank(),
