df <- read.csv("fullWAdata.csv")
df$Site <- factor(df$Site)
df$Cov <- factor(df$Cov)
df$dens_trt <- factor(df$dens_trt,
levels = c("lambda",
"High density monoculture",
"Invasion when rare (IWR)",
"IWR + Facilitator"))
df$BLK <- factor(df$BLK)
df$focsp <- factor(df$focsp)
# === Function to fit and analyze model per focal species ===
analyze_fitness_model <- function(data, family = poisson, model_label = "ZIP") {
cat("\n\n===============", model_label, "for", unique(data$focsp), "===============\n")
# Fit model
mod <- glmmTMB(fitness ~ Site * Cov * dens_trt + (1 | BLK),
ziformula = ~1,
family = family,
data = data)
print(summary(mod))
# Residual diagnostics
cat("\n-- DHARMa Residuals --\n")
simulateResiduals(mod, plot = TRUE)
# Estimated marginal means
emm <- emmeans(mod, ~ Site * Cov * dens_trt)
# Pairwise comparisons
cat("\n-- Pairwise Comparisons --\n")
print(pairs(emm, by = c("Site", "Cov")))
# Compact letter display (grouping letters)
cld_letters <- cld(emm, by = c("Site", "Cov"), Letters = letters)
# Plot predictions
emm_df <- as.data.frame(emm)
gg <- ggplot(emm_df, aes(x = Site, y = emmean, fill = Site)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9)) +
geom_errorbar(aes(ymin = emmean - SE, ymax = emmean + SE),
width = 0.2, position = position_dodge(width = 0.9)) +
facet_grid(dens_trt ~ Cov, switch = "y") +
labs(title = paste("Predicted Fitness -", model_label, "-", unique(data$focsp)),
y = "Predicted Fitness (mean ± SE)", x = "Site") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, hjust = 1))
print(gg)
return(mod)
}
# === Subset by focal species ===
df_TRCY <- filter(df, focsp == "TRCY")
df_TROR <- filter(df, focsp == "TROR")
df_TRCY
# === Analyze for TRCY ===
