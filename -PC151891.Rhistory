# Load libraries
library(lme4)
library(lmerTest)  # For p-values on fixed effects
library(emmeans)   # For post hoc comparisons, estimated marginal means
# Read your dataset
df <- read.csv("fullWAdata.csv")
# Ensure factors are properly set
df$Site <- factor(df$Site)
df$Cov <- factor(df$Cov)
df$dens_trt <- factor(df$dens_trt,
levels = c("lambda",
"High density monoculture",
"Invasion when rare (IWR)",
"IWR + Facilitator"))
df$BLK <- factor(df$BLK)
# Fit the GLMM
model <- lmer(fitness ~ Site * Cov * dens_trt + (1 | BLK), data = df)
# Optional: Estimated marginal means
emmeans_results <- emmeans(model, ~ Site * Cov * dens_trt)
summary(emmeans_results)
