ziformula = ~1,
family = nbinom2,
data = df)
summary(zinb_simple)
# Binary zero vs non-zero
df$zero <- as.numeric(df$fitness == 0)
# Logistic model
glm_zero <- glmer(zero ~ Site * Cov * dens_trt + (1 | BLK),
family = binomial, data = df)
summary(glm_zero)
